{
    "version": "8.0.12+310",
    "description": "A cross-platform manga app made for e-hentai & exhentai by Flutter.",
    "homepage": "https://github.com/jiangtian616/JHenTai",
    "license": {
        "identifier": "Apache-2.0",
        "url": "https://github.com/jiangtian616/JHenTai/blob/master/LICENSE"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/jiangtian616/JHenTai/releases/download/v8.0.12+310/JHenTai_8.0.12+310_Windows.zip",
            "hash": "9581d9ab0ac51c5fab96160a3f121499131533f6db554dad5fd831ec4a858a82"
        }
    },
    "bin": "jhentai.exe",
    "pre_install": [
        "Move-Item -Path \"$dir\\JHenTai_*\\*\" -Destination \"$dir\"",
        "Remove-Item \"$dir\\JHenTai_*\" -Force -Recurse"
    ],
    "installer": {
        "script": [
            ". \"$bucketsdir\\apeiraco\\bin\\persist-utils.ps1\"",
            "Set-PersistLinks -PersistDir $persist_dir -LinkMap @{ 'appdata' = '$env:APPDATA\\top.jtmonster\\jhentai' }"
        ]
    },
    "uninstaller": {
        "script": [
            ". \"$bucketsdir\\apeiraco\\bin\\persist-utils.ps1\"",
            "Remove-PersistLinks -PersistDir $persist_dir -LinkMap @{ 'appdata' = '$env:APPDATA\\top.jtmonster\\jhentai' }"
        ]
    },
    "shortcuts": [
        [
            "jhentai.exe",
            "JHenTai"
        ]
    ],
    "checkver": {
        "url": "https://api.github.com/repos/jiangtian616/JHenTai/releases/latest",
        "regex": "\"tag_name\":\\s*\"(v[\\d.]+(?:\\+\\d+)?)[\\s\\S]*?\"name\":\\s*\"JHenTai_([\\d.]+(?:\\+\\d+)?)_Windows\\.zip\"",
        "replace": "$2"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/jiangtian616/JHenTai/releases/download/$match1/JHenTai_$version_Windows.zip"
            }
        }
    }
}
